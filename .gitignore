# Build output (wasm + Go runtime glue). CI rebuilds web/bin/ fresh on deploy;
# static/bin and root bin/ are local-only build artifacts (not served).
/web/bin/
/web/wasm_exec.js
/web/admin/admin.wasm
**/static/bin/
/static/wasm_exec.js
/bin/
# Locally-built Go binaries (e.g. cashflux-server.exe from `go build`); rebuilt fresh, never committed.
*.exe

# Dev tooling (built gwc binary lives here; rebuild from the framework checkout)
/.tools/

# Design candidates copied into web/ for local preview (canonical copies live in design/)
/web/design/

# UI/UX review captures (screenshots + rendered text from gwc/Playwright runs).
# ALL e2e images, any format, any subdirectory — these are throwaway run output,
# never source (canonical product screenshots live in docs/screenshots/).
/.review-screenshots/
/e2e/**/*.png
/e2e/**/*.jpg
/e2e/**/*.jpeg
/e2e/**/*.gif
/e2e/**/*.webp
/e2e/.artifacts/
/e2e/serve-bin
/e2e/serve-bin.exe
# Scratch e2e probes: an underscore prefix marks throwaway one-off debug scripts
# (kept tests use descriptive names like loopstory_*.mjs / *_verify.mjs / *_check.mjs).
/e2e/_*.mjs

# Local runtime data & scratch (never commit): the self-host backend's SQLite
# database (+ WAL/SHM) and temporary logs/scratch files written during dev.
/data/
/.tmp/

# Local env / editor
.env
.env.*
*.log
.DS_Store
.vscode/
.claude/

# verification/scratch artifacts (not source).
# node_modules/ matches at any depth, so it covers ./node_modules, .tools/node_modules,
# and their .bin/ contents.
node_modules/
e2e/screenshots/
# gwc / scratch console dumps (e.g. .gwc_out2.txt, gwc_out.txt, *.gwc_run.txt)
*.gwc_*.txt
.gwc_*
gwc_out*.txt
*_gwc_out*.txt
e2e/*_output.txt
e2e/*_out.txt
# Root-level scratch screenshots dumped by verification runs (wonder_*, fix_*, etc.).
# No legitimate image lives at the repo root — real assets are in web/ and
# docs/screenshots/ — so ignore every root-level image outright.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp

# Stray root-level wasm build output (build to web/bin/ instead)
/CashFlux
sample-statement.pdf

# Personal statement samples (never leave this machine)
temp/
