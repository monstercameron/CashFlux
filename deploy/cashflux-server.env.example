# Copy to deploy/cashflux-server.env and edit before running docker compose.
# Generate token material with:
#   docker compose -f docker-compose.selfhost.yml run --rm cashflux-server rotate-token

CASHFLUX_DOMAIN=cashflux.example.com
CASHFLUX_TLS_EMAIL=admin@example.com

CASHFLUX_SERVER_AUTH_MODE=token
CASHFLUX_SERVER_BILLING=false
CASHFLUX_SERVER_STRIPE_SECRET_KEY=
CASHFLUX_SERVER_STRIPE_WEBHOOK_SECRET=
CASHFLUX_SERVER_STRIPE_PRICE_ANNUAL=
CASHFLUX_SERVER_STRIPE_PRICE_MONTHLY=
CASHFLUX_SERVER_STRIPE_SUCCESS_URL=https://cashflux.example.com/cloud/success
CASHFLUX_SERVER_STRIPE_CANCEL_URL=https://cashflux.example.com/cloud/cancel
CASHFLUX_SERVER_STRIPE_PORTAL_RETURN_URL=https://cashflux.example.com/cloud
# PayPal (optional second payment provider). API base defaults to SANDBOX; set the
# live base (https://api-m.paypal.com) explicitly for production. Create billing
# plans in the PayPal dashboard and put their plan ids here; create a webhook and
# put its id in WEBHOOK_ID. Clients choose a provider with /v1/billing/checkout?provider=paypal.
CASHFLUX_SERVER_PAYPAL_CLIENT_ID=
CASHFLUX_SERVER_PAYPAL_CLIENT_SECRET=
CASHFLUX_SERVER_PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com
CASHFLUX_SERVER_PAYPAL_WEBHOOK_ID=
CASHFLUX_SERVER_PAYPAL_PLAN_ANNUAL=
CASHFLUX_SERVER_PAYPAL_PLAN_MONTHLY=
CASHFLUX_SERVER_PAYPAL_RETURN_URL=https://cashflux.example.com/cloud/success
CASHFLUX_SERVER_PAYPAL_CANCEL_URL=https://cashflux.example.com/cloud/cancel
CASHFLUX_SERVER_APP_ORIGIN=https://cashflux.example.com
CASHFLUX_SERVER_MASTER_KEY=replace-with-32-byte-secret-from-secret-manager
CASHFLUX_SERVER_TOKEN_SHA256=replace-with-rotate-token-sha256
# Dedicated HMAC secret for signing session (access/refresh) tokens. Keep it
# separate from MASTER_KEY so an AES master-key rotation doesn't invalidate every
# session and a leak of one secret doesn't compromise the other. Any long random
# string. Recommended for multi-tenant Cloud (oauth mode).
CASHFLUX_SERVER_SESSION_KEY=replace-with-random-session-signing-secret
# During a SESSION_KEY rotation, set this to the OLD key for one refresh window so
# live sessions keep verifying; remove it once the window elapses.
# CASHFLUX_SERVER_SESSION_KEY_PREVIOUS=

# Optional OAuth mode. Set CASHFLUX_SERVER_AUTH_MODE=oauth and provide one or both providers.
# CASHFLUX_SERVER_OAUTH_GOOGLE_CLIENT_ID=
# CASHFLUX_SERVER_OAUTH_GOOGLE_CLIENT_SECRET=
# CASHFLUX_SERVER_OAUTH_GOOGLE_REDIRECT_URL=https://cashflux.example.com/v1/auth/google/callback
# CASHFLUX_SERVER_OAUTH_GITHUB_CLIENT_ID=
# CASHFLUX_SERVER_OAUTH_GITHUB_CLIENT_SECRET=
# CASHFLUX_SERVER_OAUTH_GITHUB_REDIRECT_URL=https://cashflux.example.com/v1/auth/github/callback

# Optional AI / storage limits.
CASHFLUX_SERVER_AI_UPSTREAM_TIMEOUT=45s
CASHFLUX_SERVER_AI_UPSTREAM_RETRIES=2
CASHFLUX_SERVER_AI_REQUEST_MAX_BYTES=4194304
CASHFLUX_SERVER_BLOB_MAX_BYTES=33554432
CASHFLUX_SERVER_BLOB_IO_TIMEOUT=10s
CASHFLUX_SERVER_STORAGE_WARN_BYTES=0
CASHFLUX_SERVER_STORAGE_MAX_BYTES=0
CASHFLUX_SERVER_HTTP_MAX_IN_FLIGHT=256
CASHFLUX_SERVER_HTTP_RATE_LIMIT_PER_MINUTE=0
CASHFLUX_SERVER_HTTP_USER_RATE_LIMIT_PER_MINUTE=0
# Networks (comma-separated CIDRs or bare IPs) whose X-Forwarded-For / X-Real-IP
# headers are trusted for IP-based rate limiting. Set this to your reverse proxy's
# address(es) when the server runs behind one, so rate limits key on the real client
# IP. Leave EMPTY when the server is directly internet-facing: forwarding headers are
# then ignored (they would be client-spoofable) and the socket peer is used instead.
CASHFLUX_SERVER_TRUSTED_PROXIES=
CASHFLUX_SERVER_GRPC_READ_LIMIT_BYTES=16777216
CASHFLUX_SERVER_GRPC_MAX_ACTIVE_CONNECTIONS=128
CASHFLUX_SERVER_GRPC_MAX_CONNECTIONS_PER_CLIENT=8
CASHFLUX_SERVER_GRPC_MAX_UPGRADES_PER_CLIENT_PER_MINUTE=60
CASHFLUX_SERVER_GRPC_MAX_STREAMS_PER_USER=8
# gRPC websocket-tunnel liveness. The server pings idle browser tunnels every
# KEEPALIVE_INTERVAL and closes one that fails to pong within IDLE_TIMEOUT (so a
# frozen/backgrounded tab's stream is reclaimed). Invariant enforced at startup:
# 0 < KEEPALIVE_INTERVAL < IDLE_TIMEOUT. The client also runs its own gRPC-level
# keepalive (~40s) so a half-open connection is detected browser-side and the
# watch reconnects; the server permits pings no faster than every 20s.
CASHFLUX_SERVER_GRPC_KEEPALIVE_INTERVAL=30s
CASHFLUX_SERVER_GRPC_IDLE_TIMEOUT=90s
CASHFLUX_SERVER_AUDIT_RETENTION_DAYS=365
CASHFLUX_SERVER_SNAPSHOT_HISTORY_RETENTION_DAYS=180
CASHFLUX_SERVER_BACKUP_RETENTION_DAYS=30

# Logging.
CASHFLUX_SERVER_LOG_FORMAT=text
CASHFLUX_SERVER_LOG_LEVEL=info
CASHFLUX_SERVER_LOG_HOT_PATH_SAMPLE_RATE=100
